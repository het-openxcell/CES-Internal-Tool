# Environment
ENVIRONMENT=DEV
DEBUG=True

# Backend Server
BACKEND_SERVER_HOST=0.0.0.0
BACKEND_SERVER_PORT=8000
BACKEND_SERVER_WORKERS=4

# Database - Postgres
POSTGRES_DB=your_db_name
POSTGRES_PASSWORD=your_db_password
POSTGRES_PORT=5432
POSTGRES_SCHEMA=postgresql
POSTGRES_USERNAME=your_db_user
POSTGRES_HOST=localhost
POSTGRES_URI={POSTGRES_SCHEMA}://{POSTGRES_USERNAME}:{POSTGRES_PASSWORD}@{POSTGRES_HOST}:{POSTGRES_PORT}/{POSTGRES_DB}

# Database - SQLAlchemy
DB_TIMEOUT=5
DB_POOL_SIZE=100
DB_MAX_POOL_CON=80
DB_POOL_OVERFLOW=20
IS_DB_ECHO_LOG=False
IS_DB_EXPIRE_ON_COMMIT=False
IS_DB_FORCE_ROLLBACK=True

# Credentials
IS_ALLOWED_CREDENTIALS=True

# JWT Token
JWT_SECRET_KEY=your-jwt-secret-key
JWT_SUBJECT=your-jwt-subject
JWT_FORGOT_PASSWORD_SUBJECT=password-reset
JWT_TOKEN_PREFIX=your-token-prefix
JWT_ALGORITHM=HS256
JWT_MIN=60
JWT_HOUR=23
JWT_DAY=6
JWT_MAX_DEVICES=5
JWT_IP_CHECK_ENABLED=False
JWT_SUSPICIOUS_ACTIVITY_MONITORING=True
JWT_ANDROID_DATA_COLLECTION=True

# Hash Functions
HASHING_ALGORITHM_LAYER_1=bcrypt
HASHING_ALGORITHM_LAYER_2=argon2
HASHING_SALT=your-random-salty-salt

# Logging
LOG_LEVEL=INFO

# Gemini extraction
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_EXTRACTION_MAX_CONCURRENT=3
GEMINI_EXTRACTION_MAX_RETRIES=3
LANGSMITH_TRACING=False
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ces-ddr-platform
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TAGS=ces,ddr
LANGSMITH_MAX_STRING_LENGTH=4000

# S3 Storage
S3_BUCKET_NAME=
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KEY_PREFIX=ces/

# Qdrant
QDRANT_HOST=http://localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_DDR_TIME_LOGS=ddr_time_logs